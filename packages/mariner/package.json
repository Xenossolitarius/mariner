{
  "name": "mariner-fe",
  "version": "1.0.1",
  "description": "Mariner Framework",
  "author": "Ivan Pešić",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xenossolitarius/mariner.git"
  },
  "keywords": [
    "microfrontend",
    "federation",
    "mariner-fe"
  ],
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.mts",
  "bin": {
    "mariner": "./bin/index.mjs",
    "mariner-cli": "./bin/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    },
    "./navigator": {
      "types": "./dist/navigator/index.d.mts",
      "import": "./dist/navigator/index.mjs",
      "require": "./dist/navigator/index.mjs"
    },
    "./plugins": {
      "types": "./dist/server/plugins/index.d.mts",
      "import": "./dist/server/plugins/index.mjs",
      "require": "./dist/server/plugins/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "navigator": [
        "./dist/navigator/index.d.mts"
      ],
      "plugins": [
        "./dist/server/plugins/index.d.mts"
      ]
    }
  },
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "start": "tsx ./src/cli/main.ts",
    "start:build": "tsx ./src/cli/main.ts build",
    "start:generate": "tsx ./src/cli/main.ts generate",
    "mariner-fe": "mariner-fe",
    "dev": "nodemon --config nodemon.server.json",
    "build": "obuild",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/__build-integration__/**'",
    "test:integration": "vitest run --fileParallelism=false src/__build-integration__/",
    "test:all": "vitest run",
    "test:coverage": "vitest run --coverage --exclude 'src/__build-integration__/**'",
    "test:watch": "vitest --exclude 'src/__build-integration__/**'",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --project=dev-server",
    "test:e2e:built": "playwright test --project=built-client"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "defu": "^6.1.4",
    "glob": "^13.0.6",
    "inquirer": "^13.3.2",
    "node-forge": "^1.3.3",
    "ora": "^9.3.0",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^25.0.1",
    "vitest": "^4.1.0",
    "vue": "^3.5.30"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
